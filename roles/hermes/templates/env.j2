{{ ansible_managed | comment }}
# Managed scope environment, overrides ~/.hermes/.env and the shell environment
# for the keys set here.
{% for name, value in (hermes_managed_env | dictsort) if value not in [none, ''] %}
{{ name }}={{ value }}
{% endfor %}
{% for name, entry in (hermes_managed_env_secrets | dictsort) %}
{{ name }}={{ lookup('community.general.passwordstore', entry, returnall=true) | trim }}
{% endfor %}
