{{ ansible_managed | comment }}
# Drop-in over the unit generated by "hermes gateway install --system": it owns
# the service definition, this file owns identity, environment and hardening.
[Service]
User={{ hermes_user }}
Group={{ hermes_group }}
WorkingDirectory={{ hermes_home }}
Environment=HERMES_HOME={{ hermes_home }}
# The generated unit bakes in the environment of whoever ran the installer, so
# HOME would point at that user's home - unreachable under ProtectHome and not
# writable for the service. A later assignment of the same variable wins.
Environment=HOME={{ hermes_home }}
Environment=USER={{ hermes_user }}
Environment=LOGNAME={{ hermes_user }}
{% if hermes_config_dir != '/etc/hermes' %}
Environment=HERMES_MANAGED_DIR={{ hermes_config_dir }}
{% endif %}
{% if hermes_service_hardening %}

# The agent runs its own shell commands, so it is confined to its state
# directory: everything else is read only for the service.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths={{ ([hermes_home] + hermes_service_read_write_paths) | join(' ') }}
ProtectKernelTunables=yes
ProtectControlGroups=yes
{% endif %}
